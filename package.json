{
  "name": "sales-agent-obsidian-notes",
  "private": true,
  "description": "Obsidian vault for sales-agent notes (synced standalone from parent monorepo path)",
  "scripts": {
    "prepare": "husky",
    "lint": "markdownlint-cli2 \"**/*.md\" \"#node_modules\" \"#.git\"",
    "format": "prettier --write \"**/*.md\"",
    "format:check": "prettier --check \"**/*.md\"",
    "validate:people": "node scripts/people-outreach-wave.mjs validate",
    "validate:outreach-status": "node scripts/person-outreach-status.mjs validate",
    "validate:outreach-sends": "node scripts/outreach-send-template.mjs validate",
    "validate:outreach-send-fields": "node scripts/outreach-send-fields.mjs validate",
    "check": "pnpm run lint && pnpm run format:check && pnpm run validate:people && pnpm run validate:outreach-status && pnpm run validate:outreach-sends && pnpm run validate:outreach-send-fields",
    "fix": "pnpm run format && pnpm run lint",
    "test": "node --test scripts/person-outreach-status.test.mjs scripts/outreach-send-template.test.mjs scripts/outreach-send-fields.test.mjs"
  },
  "lint-staged": {
    "*.md": ["prettier --write", "markdownlint-cli2 --fix"]
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^15.5.1",
    "markdownlint-cli2": "^0.17.2",
    "prettier": "^3.5.3"
  }
}
