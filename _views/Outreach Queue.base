filters:
  and:
    - file.inFolder("Outreach Sends")
formulas:
  sent_ago: if(sent_at, sent_at.relative(), "")
  responded_ago: if(responded_at, responded_at.relative(), "")
  mailto_to: 'if(people && !list(people).isEmpty() && list(people)[0].asFile().hasProperty("email"), list(people)[0].asFile().properties.email, if(thread_url && thread_url.contains("mailto:"), (thread_url.replace("mailto:", "")).split("?", 2)[0], ""))'
  mailto_subject_enc: 'if(subject, subject.replace(/%/g, "%25").replace(/&/g, "%26").replace(/#/g, "%23").replace(/\?/g, "%3F").replace(/\n/g, "%0A").replace(/\r/g, "").replace(/ /g, "%20"), "")'
  mailto_body_enc: 'if(body, body.replace(/%/g, "%25").replace(/&/g, "%26").replace(/#/g, "%23").replace(/\?/g, "%3F").replace(/=/g, "%3D").replace(/\n/g, "%0A").replace(/\r/g, "").replace(/ /g, "%20"), "")'
  mailto_href: 'if(formula.mailto_to, "mailto:" + formula.mailto_to + "?subject=" + formula.mailto_subject_enc + "&body=" + formula.mailto_body_enc, "")'
  mailto_send: 'if(formula.mailto_href, link(formula.mailto_href, "Send"), "")'
properties:
  file.name:
    displayName: Send
  file.mtime:
    displayName: Updated
  channel:
    displayName: Channel
  step:
    displayName: Step
  subject:
    displayName: Subject
  body:
    displayName: Body
  sent_at:
    displayName: Sent at
  responded_at:
    displayName: Responded at
  formula.sent_ago:
    displayName: Sent timing
  formula.responded_ago:
    displayName: Reply timing
  formula.mailto_send:
    displayName: Open mail
  template:
    displayName: Template
  people:
    displayName: People
  thread_url:
    displayName: Thread / mailto
views:
  - type: table
    name: Ready to send
    filters:
      and:
        - sent_at == null
        - if(subject, !subject.isEmpty(), false)
        - if(body, !body.isEmpty(), false)
    order:
      - file.name
      - people
      - subject
      - formula.mailto_send
      - body
      - channel
      - thread_url
      - template
      - sent_at
      - file.mtime
    sort:
      - property: sent_at
        direction: ASC
  - type: table
    name: Unsent — still drafting
    filters:
      and:
        - sent_at == null
        - not:
            - if(subject, !subject.isEmpty(), false) && if(body, !body.isEmpty(), false)
    order:
      - file.name
      - people
      - subject
      - formula.mailto_send
      - body
      - channel
      - template
      - sent_at
      - file.mtime
  - type: table
    name: Sent log
    filters: sent_at != null
    order:
      - file.name
      - people
      - subject
      - formula.mailto_send
      - body
      - sent_at
      - formula.sent_ago
      - responded_at
      - formula.responded_ago
      - step
      - file.mtime
